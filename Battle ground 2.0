<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Pixel Battlegrounds</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body {
            margin: 0;
            padding: 0;
            overflow: hidden;
            background-color: #1a1a1a;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            touch-action: none;
        }
        #game-container {
            position: relative;
            width: 100vw;
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }
        canvas {
            display: block;
            background-color: #4d7c0f; /* Grass color */
            box-shadow: 0 0 50px rgba(0,0,0,0.5);
        }
        #ui-layer {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            color: white;
            padding: 20px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }
        .joy-stick-container {
            position: absolute;
            bottom: 40px;
            left: 40px;
            width: 120px;
            height: 120px;
            background: rgba(255,255,255,0.1);
            border-radius: 50%;
            pointer-events: auto;
        }
        .joy-stick-knob {
            position: absolute;
            top: 50%;
            left: 50%;
            width: 50px;
            height: 50px;
            background: rgba(255,255,255,0.5);
            border-radius: 50%;
            transform: translate(-50%, -50%);
        }
        #overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.8);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            z-index: 100;
            pointer-events: auto;
        }
        .btn {
            background: #facc15;
            color: black;
            padding: 15px 40px;
            border-radius: 8px;
            font-weight: bold;
            cursor: pointer;
            margin-top: 20px;
            transition: transform 0.1s;
        }
        .btn:active { transform: scale(0.95); }
    </style>
</head>
<body>

<div id="game-container">
    <canvas id="gameCanvas"></canvas>
    
    <div id="ui-layer">
        <div class="flex justify-between items-start">
            <div class="bg-black/50 p-3 rounded border border-white/20">
                <div id="player-hp-bar" class="w-48 h-4 bg-gray-700 rounded-full overflow-hidden">
                    <div id="player-hp-fill" class="h-full bg-green-500 transition-all duration-300" style="width: 100%"></div>
                </div>
                <div class="text-xs mt-1 uppercase font-bold tracking-widest">Health</div>
            </div>
            <div class="text-right">
                <div class="text-3xl font-black italic text-yellow-400" id="alive-count">ALIVE: 20</div>
                <div class="text-sm font-bold text-blue-300" id="zone-timer">ZONE SHRINKING: 30s</div>
            </div>
        </div>

        <div class="flex justify-between items-end mb-4">
            <div id="weapon-info" class="bg-black/50 p-3 rounded border border-white/20">
                <div class="text-xl font-bold" id="current-weapon">FISTS</div>
                <div class="text-sm text-gray-300" id="ammo-count">∞</div>
            </div>
            
            <div class="flex flex-col gap-2 pointer-events-auto">
                <button id="fire-btn" class="w-20 h-20 bg-red-600/80 rounded-full border-4 border-white/40 active:bg-red-800 flex items-center justify-center">
                    <span class="font-bold">FIRE</span>
                </button>
            </div>
        </div>
    </div>

    <div id="overlay">
        <h1 class="text-6xl font-black italic text-yellow-400 mb-2">PIXEL BG</h1>
        <p class="text-white text-lg mb-8">Be the last one standing.</p>
        <div class="text-gray-400 text-sm mb-8 text-center">
            WASD / Joystick to Move<br>
            Mouse / Drag to Aim<br>
            Click / Fire Button to Shoot
        </div>
        <div id="start-btn" class="btn text-2xl">START MATCH</div>
    </div>
</div>

<script>
    /** @type {HTMLCanvasElement} */
    const canvas = document.getElementById('gameCanvas');
    const ctx = canvas.getContext('2d');
    const overlay = document.getElementById('overlay');
    const startBtn = document.getElementById('start-btn');
    const hpFill = document.getElementById('player-hp-fill');
    const aliveDisplay = document.getElementById('alive-count');
    const weaponDisplay = document.getElementById('current-weapon');
    const ammoDisplay = document.getElementById('ammo-count');
    const zoneTimerDisplay = document.getElementById('zone-timer');

    // Game Constants
    const WORLD_SIZE = 3000;
    const PLAYER_SPEED = 4;
    const AI_COUNT = 19;
    
    // State
    let gameRunning = false;
    let player = {
        x: WORLD_SIZE / 2,
        y: WORLD_SIZE / 2,
        radius: 20,
        angle: 0,
        hp: 100,
        weapon: { name: 'Pistol', damage: 15, cooldown: 400, ammo: 12, maxAmmo: 12, speed: 12, color: '#fbbf24' },
        lastShot: 0
    };

    let camera = { x: 0, y: 0 };
    let keys = {};
    let enemies = [];
    let bullets = [];
    let items = [];
    let particles = [];
    let zone = { x: WORLD_SIZE/2, y: WORLD_SIZE/2, radius: WORLD_SIZE * 0.7, targetRadius: WORLD_SIZE * 0.7 };
    let zoneTimer = 15; // seconds
    let aliveCount = AI_COUNT + 1;

    // Initialization
    function init() {
        resize();
        spawnEnemies();
        spawnItems();
        gameRunning = true;
        overlay.style.display = 'none';
        requestAnimationFrame(gameLoop);
        
        setInterval(() => {
            if (zoneTimer > 0) zoneTimer--;
            else {
                zone.targetRadius *= 0.7;
                zoneTimer = 20;
            }
            zoneTimerDisplay.innerText = `NEXT SHRINK: ${zoneTimer}s`;
        }, 1000);
    }

    function resize() {
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
    }

    window.addEventListener('resize', resize);

    // Input Handling
    window.addEventListener('keydown', e => keys[e.code] = true);
    window.addEventListener('keyup', e => keys[e.code] = false);
    
    let isMouseDown = false;
    let mousePos = { x: 0, y: 0 };

    canvas.addEventListener('mousemove', e => {
        mousePos.x = e.clientX;
        mousePos.y = e.clientY;
    });
    canvas.addEventListener('mousedown', () => isMouseDown = true);
    canvas.addEventListener('mouseup', () => isMouseDown = false);
    document.getElementById('fire-btn').addEventListener('touchstart', (e) => { e.preventDefault(); isMouseDown = true; });
    document.getElementById('fire-btn').addEventListener('touchend', () => isMouseDown = false);

    function spawnEnemies() {
        for(let i=0; i<AI_COUNT; i++) {
            enemies.push({
                x: Math.random() * WORLD_SIZE,
                y: Math.random() * WORLD_SIZE,
                radius: 20,
                hp: 100,
                angle: Math.random() * Math.PI * 2,
                weapon: { name: 'Pistol', damage: 10, cooldown: 1000, speed: 8 },
                lastShot: 0,
                targetX: Math.random() * WORLD_SIZE,
                targetY: Math.random() * WORLD_SIZE,
                aiTimer: 0
            });
        }
    }

    function spawnItems() {
        const weaponTypes = [
            { name: 'SMG', damage: 8, cooldown: 120, ammo: 30, maxAmmo: 30, speed: 15, color: '#f87171' },
            { name: 'Rifle', damage: 25, cooldown: 600, ammo: 10, maxAmmo: 10, speed: 20, color: '#60a5fa' }
        ];
        for(let i=0; i<40; i++) {
            items.push({
                x: Math.random() * WORLD_SIZE,
                y: Math.random() * WORLD_SIZE,
                type: Math.random() > 0.3 ? 'weapon' : 'health',
                data: Math.random() > 0.5 ? weaponTypes[0] : weaponTypes[1]
            });
        }
    }

    function shoot(owner, isPlayer = false) {
        const now = Date.now();
        if (now - owner.lastShot < owner.weapon.cooldown) return;
        if (isPlayer && owner.weapon.ammo <= 0) return;

        owner.lastShot = now;
        if (isPlayer) owner.weapon.ammo--;

        bullets.push({
            x: owner.x + Math.cos(owner.angle) * 30,
            y: owner.y + Math.sin(owner.angle) * 30,
            vx: Math.cos(owner.angle) * owner.weapon.speed,
            vy: Math.sin(owner.angle) * owner.weapon.speed,
            damage: owner.weapon.damage,
            owner: owner,
            color: owner.weapon.color || 'white'
        });

        // Muzzle flash particle
        createExplosion(owner.x + Math.cos(owner.angle) * 25, owner.y + Math.sin(owner.angle) * 25, owner.weapon.color, 3);
    }

    function createExplosion(x, y, color, count = 10) {
        for(let i=0; i<count; i++) {
            particles.push({
                x, y,
                vx: (Math.random() - 0.5) * 5,
                vy: (Math.random() - 0.5) * 5,
                life: 1.0,
                color: color || '#fff'
            });
        }
    }

    function update() {
        // Player Movement
        let dx = 0, dy = 0;
        if (keys['KeyW'] || keys['ArrowUp']) dy -= 1;
        if (keys['KeyS'] || keys['ArrowDown']) dy += 1;
        if (keys['KeyA'] || keys['ArrowLeft']) dx -= 1;
        if (keys['KeyD'] || keys['ArrowRight']) dx += 1;

        if (dx !== 0 || dy !== 0) {
            const mag = Math.sqrt(dx*dx + dy*dy);
            player.x += (dx/mag) * PLAYER_SPEED;
            player.y += (dy/mag) * PLAYER_SPEED;
        }

        // Mouse Aiming
        const screenCenterX = canvas.width / 2;
        const screenCenterY = canvas.height / 2;
        player.angle = Math.atan2(mousePos.y - screenCenterY, mousePos.x - screenCenterX);

        if (isMouseDown) shoot(player, true);

        // Bounds
        player.x = Math.max(0, Math.min(WORLD_SIZE, player.x));
        player.y = Math.max(0, Math.min(WORLD_SIZE, player.y));

        // Camera
        camera.x = player.x - canvas.width / 2;
        camera.y = player.y - canvas.height / 2;

        // Zone Logic
        if (zone.radius > zone.targetRadius) zone.radius -= 0.5;
        const distToZoneCenter = Math.sqrt((player.x - zone.x)**2 + (player.y - zone.y)**2);
        if (distToZoneCenter > zone.radius) {
            player.hp -= 0.1;
        }

        // Items logic
        items = items.filter(item => {
            const dist = Math.sqrt((player.x - item.x)**2 + (player.y - item.y)**2);
            if (dist < 40) {
                if (item.type === 'weapon') {
                    player.weapon = JSON.parse(JSON.stringify(item.data));
                } else {
                    player.hp = Math.min(100, player.hp + 30);
                }
                return false;
            }
            return true;
        });

        // AI Logic
        enemies.forEach(en => {
            // Movement AI
            en.aiTimer--;
            if(en.aiTimer <= 0) {
                en.targetX = Math.random() * WORLD_SIZE;
                en.targetY = Math.random() * WORLD_SIZE;
                en.aiTimer = 100 + Math.random() * 200;
            }
            const edx = en.targetX - en.x;
            const edy = en.targetY - en.y;
            const edist = Math.sqrt(edx*edx + edy*edy);
            if (edist > 5) {
                en.x += (edx/edist) * 2;
                en.y += (edy/edist) * 2;
                en.angle = Math.atan2(edy, edx);
            }

            // Shooting AI
            const distToPlayer = Math.sqrt((player.x - en.x)**2 + (player.y - en.y)**2);
            if (distToPlayer < 400) {
                en.angle = Math.atan2(player.y - en.y, player.x - en.x);
                shoot(en);
            }

            // Zone damage for AI
            const distToZone = Math.sqrt((en.x - zone.x)**2 + (en.y - zone.y)**2);
            if (distToZone > zone.radius) en.hp -= 0.2;
        });

        // Bullets
        bullets.forEach((b, i) => {
            b.x += b.vx;
            b.y += b.vy;

            // Collision with player
            if (b.owner !== player) {
                const d = Math.sqrt((b.x - player.x)**2 + (b.y - player.y)**2);
                if (d < player.radius) {
                    player.hp -= b.damage;
                    createExplosion(b.x, b.y, 'red', 5);
                    bullets.splice(i, 1);
                    return;
                }
            }

            // Collision with enemies
            enemies.forEach((en, ei) => {
                if (b.owner !== en) {
                    const d = Math.sqrt((b.x - en.x)**2 + (b.y - en.y)**2);
                    if (d < en.radius) {
                        en.hp -= b.damage;
                        createExplosion(b.x, b.y, 'white', 5);
                        bullets.splice(i, 1);
                        if (en.hp <= 0) {
                            enemies.splice(ei, 1);
                            createExplosion(en.x, en.y, '#555', 20);
                        }
                    }
                }
            });

            // Cleanup
            if (b.x < 0 || b.x > WORLD_SIZE || b.y < 0 || b.y > WORLD_SIZE) {
                bullets.splice(i, 1);
            }
        });

        // Particles
        particles.forEach((p, i) => {
            p.x += p.vx;
            p.y += p.vy;
            p.life -= 0.02;
            if (p.life <= 0) particles.splice(i, 1);
        });

        // UI Update
        hpFill.style.width = Math.max(0, player.hp) + '%';
        if (player.hp < 30) hpFill.classList.replace('bg-green-500', 'bg-red-500');
        else hpFill.classList.replace('bg-red-500', 'bg-green-500');

        aliveCount = enemies.length + 1;
        aliveDisplay.innerText = `ALIVE: ${aliveCount}`;
        weaponDisplay.innerText = player.weapon.name;
        ammoDisplay.innerText = player.weapon.ammo !== undefined ? player.weapon.ammo : '∞';

        if (player.hp <= 0) gameOver("ELIMINATED");
        if (aliveCount === 1 && player.hp > 0) gameOver("WINNER WINNER!");
    }

    function draw() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        ctx.save();
        ctx.translate(-camera.x, -camera.y);

        // Draw World Grid
        ctx.strokeStyle = 'rgba(255,255,255,0.05)';
        ctx.lineWidth = 2;
        for (let x = 0; x <= WORLD_SIZE; x += 100) {
            ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x, WORLD_SIZE); ctx.stroke();
        }
        for (let y = 0; y <= WORLD_SIZE; y += 100) {
            ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(WORLD_SIZE, y); ctx.stroke();
        }

        // Draw Zone
        ctx.beginPath();
        ctx.arc(zone.x, zone.y, zone.radius, 0, Math.PI * 2);
        ctx.strokeStyle = '#3b82f6';
        ctx.lineWidth = 10;
        ctx.stroke();
        
        // Items
        items.forEach(item => {
            ctx.fillStyle = item.type === 'weapon' ? '#facc15' : '#ef4444';
            ctx.beginPath();
            ctx.roundRect(item.x - 10, item.y - 10, 20, 20, 4);
            ctx.fill();
            ctx.fillStyle = 'white';
            ctx.font = '10px bold Arial';
            ctx.fillText(item.type === 'weapon' ? 'WPN' : 'MED', item.x - 12, item.y - 15);
        });

        // Particles
        particles.forEach(p => {
            ctx.globalAlpha = p.life;
            ctx.fillStyle = p.color;
            ctx.beginPath();
            ctx.arc(p.x, p.y, 3, 0, Math.PI * 2);
            ctx.fill();
        });
        ctx.globalAlpha = 1;

        // Enemies
        enemies.forEach(en => {
            drawCharacter(en, '#1e293b');
        });

        // Player
        drawCharacter(player, '#facc15');

        // Bullets
        bullets.forEach(b => {
            ctx.fillStyle = b.color;
            ctx.beginPath();
            ctx.arc(b.x, b.y, 4, 0, Math.PI * 2);
            ctx.fill();
        });

        ctx.restore();
    }

    function drawCharacter(char, color) {
        ctx.save();
        ctx.translate(char.x, char.y);
        ctx.rotate(char.angle);

        // Body
        ctx.fillStyle = color;
        ctx.beginPath();
        ctx.arc(0, 0, char.radius, 0, Math.PI * 2);
        ctx.fill();
        ctx.strokeStyle = 'rgba(0,0,0,0.3)';
        ctx.lineWidth = 3;
        ctx.stroke();

        // Hands / Weapon
        ctx.fillStyle = color;
        ctx.fillRect(15, -18, 20, 10);
        ctx.fillRect(15, 8, 20, 10);
        
        // Gun
        ctx.fillStyle = '#333';
        ctx.fillRect(25, -4, 25, 8);

        ctx.restore();

        // HP Bar overhead
        ctx.fillStyle = '#333';
        ctx.fillRect(char.x - 20, char.y - 40, 40, 5);
        ctx.fillStyle = char.hp > 40 ? '#4ade80' : '#f87171';
        ctx.fillRect(char.x - 20, char.y - 40, (char.hp / 100) * 40, 5);
    }

    function gameOver(text) {
        gameRunning = false;
        overlay.style.display = 'flex';
        overlay.querySelector('h1').innerText = text;
        overlay.querySelector('p').innerText = "Match Over";
        startBtn.innerText = "RESTART";
    }

    function gameLoop() {
        if (!gameRunning) return;
        update();
        draw();
        requestAnimationFrame(gameLoop);
    }

    startBtn.addEventListener('click', () => {
        // Reset State
        player.hp = 100;
        player.x = WORLD_SIZE / 2;
        player.y = WORLD_SIZE / 2;
        player.weapon = { name: 'Pistol', damage: 15, cooldown: 400, ammo: 12, maxAmmo: 12, speed: 12, color: '#fbbf24' };
        enemies = [];
        bullets = [];
        items = [];
        particles = [];
        zone.radius = WORLD_SIZE * 0.7;
        zone.targetRadius = WORLD_SIZE * 0.7;
        zoneTimer = 15;
        
        init();
    });

</script>
</body>
</html>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Pixel Battlegrounds</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body {
            margin: 0;
            padding: 0;
            overflow: hidden;
            background-color: #1a1a1a;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            touch-action: none;
        }
        #game-container {
            position: relative;
            width: 100vw;
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }
        canvas {
            display: block;
            background-color: #4d7c0f; /* Grass color */
            box-shadow: 0 0 50px rgba(0,0,0,0.5);
        }
        #ui-layer {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            color: white;
            padding: 15px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }
        #minimap-container {
            width: 150px;
            height: 150px;
            background: rgba(0, 0, 0, 0.6);
            border: 2px solid rgba(255, 255, 255, 0.3);
            border-radius: 8px;
            overflow: hidden;
            position: relative;
        }
        #minimap-canvas {
            width: 100%;
            height: 100%;
        }
        #overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.8);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            z-index: 100;
            pointer-events: auto;
        }
        .btn {
            background: #facc15;
            color: black;
            padding: 15px 40px;
            border-radius: 8px;
            font-weight: bold;
            cursor: pointer;
            margin-top: 20px;
            transition: transform 0.1s;
        }
        .btn:active { transform: scale(0.95); }
    </style>
</head>
<body>

<div id="game-container">
    <canvas id="gameCanvas"></canvas>
    
    <div id="ui-layer">
        <div class="flex justify-between items-start">
            <div class="flex flex-col gap-2">
                <!-- Mini Map -->
                <div id="minimap-container">
                    <canvas id="minimap-canvas"></canvas>
                </div>
                <!-- Health Bar -->
                <div class="bg-black/50 p-3 rounded border border-white/20">
                    <div id="player-hp-bar" class="w-32 h-3 bg-gray-700 rounded-full overflow-hidden">
                        <div id="player-hp-fill" class="h-full bg-green-500 transition-all duration-300" style="width: 100%"></div>
                    </div>
                    <div class="text-[10px] mt-1 uppercase font-bold tracking-widest">Health</div>
                </div>
            </div>

            <div class="text-right">
                <div class="text-3xl font-black italic text-yellow-400" id="alive-count">ALIVE: 20</div>
                <div class="text-sm font-bold text-blue-300" id="zone-timer">ZONE SHRINKING: 30s</div>
            </div>
        </div>

        <div class="flex justify-between items-end mb-4">
            <div id="weapon-info" class="bg-black/50 p-3 rounded border border-white/20">
                <div class="text-xl font-bold" id="current-weapon">FISTS</div>
                <div class="text-sm text-gray-300" id="ammo-count">∞</div>
            </div>
            
            <div class="flex flex-col gap-2 pointer-events-auto">
                <button id="fire-btn" class="w-24 h-24 bg-red-600/80 rounded-full border-4 border-white/40 active:bg-red-800 flex items-center justify-center shadow-lg">
                    <span class="font-bold text-lg">FIRE</span>
                </button>
            </div>
        </div>
    </div>

    <div id="overlay">
        <h1 class="text-6xl font-black italic text-yellow-400 mb-2">PIXEL BG</h1>
        <p class="text-white text-lg mb-8">Be the last one standing.</p>
        <div class="text-gray-400 text-sm mb-8 text-center">
            WASD / Joystick to Move<br>
            Mouse / Drag to Aim<br>
            Click / Fire Button to Shoot<br>
            Watch the Mini-Map for the Zone!
        </div>
        <div id="start-btn" class="btn text-2xl">START MATCH</div>
    </div>
</div>

<script>
    /** @type {HTMLCanvasElement} */
    const canvas = document.getElementById('gameCanvas');
    const ctx = canvas.getContext('2d');
    const mCanvas = document.getElementById('minimap-canvas');
    const mCtx = mCanvas.getContext('2d');

    const overlay = document.getElementById('overlay');
    const startBtn = document.getElementById('start-btn');
    const hpFill = document.getElementById('player-hp-fill');
    const aliveDisplay = document.getElementById('alive-count');
    const weaponDisplay = document.getElementById('current-weapon');
    const ammoDisplay = document.getElementById('ammo-count');
    const zoneTimerDisplay = document.getElementById('zone-timer');

    // Game Constants
    const WORLD_SIZE = 3000;
    const PLAYER_SPEED = 4.5;
    const AI_COUNT = 19;
    
    // State
    let gameRunning = false;
    let player = {
        x: WORLD_SIZE / 2,
        y: WORLD_SIZE / 2,
        radius: 20,
        angle: 0,
        hp: 100,
        weapon: { name: 'Pistol', damage: 15, cooldown: 400, ammo: 12, maxAmmo: 12, speed: 12, color: '#fbbf24' },
        lastShot: 0
    };

    let camera = { x: 0, y: 0 };
    let keys = {};
    let enemies = [];
    let bullets = [];
    let items = [];
    let particles = [];
    let zone = { x: WORLD_SIZE/2, y: WORLD_SIZE/2, radius: WORLD_SIZE * 0.75, targetRadius: WORLD_SIZE * 0.75 };
    let zoneTimer = 15; 
    let aliveCount = AI_COUNT + 1;

    // Initialization
    function init() {
        resize();
        spawnEnemies();
        spawnItems();
        gameRunning = true;
        overlay.style.display = 'none';
        requestAnimationFrame(gameLoop);
        
        const timerInt = setInterval(() => {
            if (!gameRunning) { clearInterval(timerInt); return; }
            if (zoneTimer > 0) zoneTimer--;
            else {
                zone.targetRadius *= 0.7;
                zoneTimer = 25;
            }
            zoneTimerDisplay.innerText = `NEXT SHRINK: ${zoneTimer}s`;
        }, 1000);
    }

    function resize() {
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
        // Map canvas resolution
        mCanvas.width = 150;
        mCanvas.height = 150;
    }

    window.addEventListener('resize', resize);

    // Input Handling
    window.addEventListener('keydown', e => keys[e.code] = true);
    window.addEventListener('keyup', e => keys[e.code] = false);
    
    let isMouseDown = false;
    let mousePos = { x: 0, y: 0 };

    canvas.addEventListener('mousemove', e => {
        mousePos.x = e.clientX;
        mousePos.y = e.clientY;
    });
    canvas.addEventListener('mousedown', () => isMouseDown = true);
    canvas.addEventListener('mouseup', () => isMouseDown = false);
    document.getElementById('fire-btn').addEventListener('touchstart', (e) => { e.preventDefault(); isMouseDown = true; });
    document.getElementById('fire-btn').addEventListener('touchend', () => isMouseDown = false);

    function spawnEnemies() {
        for(let i=0; i<AI_COUNT; i++) {
            enemies.push({
                x: Math.random() * WORLD_SIZE,
                y: Math.random() * WORLD_SIZE,
                radius: 20,
                hp: 100,
                angle: Math.random() * Math.PI * 2,
                weapon: { name: 'Pistol', damage: 10, cooldown: 1000, speed: 8 },
                lastShot: 0,
                targetX: Math.random() * WORLD_SIZE,
                targetY: Math.random() * WORLD_SIZE,
                aiTimer: 0
            });
        }
    }

    function spawnItems() {
        const weaponTypes = [
            { name: 'SMG', damage: 8, cooldown: 120, ammo: 30, maxAmmo: 30, speed: 15, color: '#f87171' },
            { name: 'Rifle', damage: 25, cooldown: 600, ammo: 10, maxAmmo: 10, speed: 20, color: '#60a5fa' }
        ];
        for(let i=0; i<60; i++) {
            items.push({
                x: Math.random() * WORLD_SIZE,
                y: Math.random() * WORLD_SIZE,
                type: Math.random() > 0.4 ? 'weapon' : 'health',
                data: Math.random() > 0.5 ? weaponTypes[0] : weaponTypes[1]
            });
        }
    }

    function shoot(owner, isPlayer = false) {
        const now = Date.now();
        if (now - owner.lastShot < owner.weapon.cooldown) return;
        if (isPlayer && owner.weapon.ammo <= 0) return;

        owner.lastShot = now;
        if (isPlayer) owner.weapon.ammo--;

        bullets.push({
            x: owner.x + Math.cos(owner.angle) * 30,
            y: owner.y + Math.sin(owner.angle) * 30,
            vx: Math.cos(owner.angle) * owner.weapon.speed,
            vy: Math.sin(owner.angle) * owner.weapon.speed,
            damage: owner.weapon.damage,
            owner: owner,
            color: owner.weapon.color || 'white'
        });

        createExplosion(owner.x + Math.cos(owner.angle) * 25, owner.y + Math.sin(owner.angle) * 25, owner.weapon.color, 3);
    }

    function createExplosion(x, y, color, count = 10) {
        for(let i=0; i<count; i++) {
            particles.push({
                x, y,
                vx: (Math.random() - 0.5) * 5,
                vy: (Math.random() - 0.5) * 5,
                life: 1.0,
                color: color || '#fff'
            });
        }
    }

    function update() {
        // Player Movement
        let dx = 0, dy = 0;
        if (keys['KeyW'] || keys['ArrowUp']) dy -= 1;
        if (keys['KeyS'] || keys['ArrowDown']) dy += 1;
        if (keys['KeyA'] || keys['ArrowLeft']) dx -= 1;
        if (keys['KeyD'] || keys['ArrowRight']) dx += 1;

        if (dx !== 0 || dy !== 0) {
            const mag = Math.sqrt(dx*dx + dy*dy);
            player.x += (dx/mag) * PLAYER_SPEED;
            player.y += (dy/mag) * PLAYER_SPEED;
        }

        const screenCenterX = canvas.width / 2;
        const screenCenterY = canvas.height / 2;
        player.angle = Math.atan2(mousePos.y - screenCenterY, mousePos.x - screenCenterX);

        if (isMouseDown) shoot(player, true);

        player.x = Math.max(0, Math.min(WORLD_SIZE, player.x));
        player.y = Math.max(0, Math.min(WORLD_SIZE, player.y));

        camera.x = player.x - canvas.width / 2;
        camera.y = player.y - canvas.height / 2;

        if (zone.radius > zone.targetRadius) zone.radius -= 0.3;
        const distToZoneCenter = Math.sqrt((player.x - zone.x)**2 + (player.y - zone.y)**2);
        if (distToZoneCenter > zone.radius) player.hp -= 0.15;

        items = items.filter(item => {
            const dist = Math.sqrt((player.x - item.x)**2 + (player.y - item.y)**2);
            if (dist < 40) {
                if (item.type === 'weapon') player.weapon = JSON.parse(JSON.stringify(item.data));
                else player.hp = Math.min(100, player.hp + 40);
                return false;
            }
            return true;
        });

        enemies.forEach(en => {
            en.aiTimer--;
            if(en.aiTimer <= 0) {
                en.targetX = Math.random() * WORLD_SIZE;
                en.targetY = Math.random() * WORLD_SIZE;
                en.aiTimer = 100 + Math.random() * 200;
            }
            const edx = en.targetX - en.x;
            const edy = en.targetY - en.y;
            const edist = Math.sqrt(edx*edx + edy*edy);
            if (edist > 5) {
                en.x += (edx/edist) * 2.2;
                en.y += (edy/edist) * 2.2;
                en.angle = Math.atan2(edy, edx);
            }

            const distToPlayer = Math.sqrt((player.x - en.x)**2 + (player.y - en.y)**2);
            if (distToPlayer < 450) {
                en.angle = Math.atan2(player.y - en.y, player.x - en.x);
                shoot(en);
            }

            const distToZone = Math.sqrt((en.x - zone.x)**2 + (en.y - zone.y)**2);
            if (distToZone > zone.radius) en.hp -= 0.3;
        });

        bullets.forEach((b, i) => {
            b.x += b.vx;
            b.y += b.vy;

            if (b.owner !== player) {
                const d = Math.sqrt((b.x - player.x)**2 + (b.y - player.y)**2);
                if (d < player.radius) {
                    player.hp -= b.damage;
                    createExplosion(b.x, b.y, 'red', 5);
                    bullets.splice(i, 1);
                    return;
                }
            }

            enemies.forEach((en, ei) => {
                if (b.owner !== en) {
                    const d = Math.sqrt((b.x - en.x)**2 + (b.y - en.y)**2);
                    if (d < en.radius) {
                        en.hp -= b.damage;
                        createExplosion(b.x, b.y, 'white', 5);
                        bullets.splice(i, 1);
                        if (en.hp <= 0) {
                            enemies.splice(ei, 1);
                            createExplosion(en.x, en.y, '#555', 20);
                        }
                    }
                }
            });

            if (b.x < 0 || b.x > WORLD_SIZE || b.y < 0 || b.y > WORLD_SIZE) bullets.splice(i, 1);
        });

        particles.forEach((p, i) => {
            p.x += p.vx;
            p.y += p.vy;
            p.life -= 0.02;
            if (p.life <= 0) particles.splice(i, 1);
        });

        hpFill.style.width = Math.max(0, player.hp) + '%';
        aliveCount = enemies.length + 1;
        aliveDisplay.innerText = `ALIVE: ${aliveCount}`;
        weaponDisplay.innerText = player.weapon.name;
        ammoDisplay.innerText = player.weapon.ammo !== undefined ? player.weapon.ammo : '∞';

        if (player.hp <= 0) gameOver("ELIMINATED");
        if (aliveCount === 1 && player.hp > 0) gameOver("WINNER WINNER!");
    }

    function drawMinimap() {
        mCtx.fillStyle = 'rgba(0, 0, 0, 0.8)';
        mCtx.fillRect(0, 0, mCanvas.width, mCanvas.height);

        const scale = mCanvas.width / WORLD_SIZE;

        // Draw Zone in Map
        mCtx.beginPath();
        mCtx.arc(zone.x * scale, zone.y * scale, zone.radius * scale, 0, Math.PI * 2);
        mCtx.strokeStyle = '#3b82f6';
        mCtx.lineWidth = 1.5;
        mCtx.stroke();

        // Items
        items.forEach(item => {
            mCtx.fillStyle = item.type === 'weapon' ? '#facc15' : '#ef4444';
            mCtx.fillRect(item.x * scale - 1, item.y * scale - 1, 2, 2);
        });

        // Enemies
        mCtx.fillStyle = '#ef4444';
        enemies.forEach(en => {
            mCtx.beginPath();
            mCtx.arc(en.x * scale, en.y * scale, 2.5, 0, Math.PI * 2);
            mCtx.fill();
        });

        // Player
        mCtx.fillStyle = '#facc15';
        mCtx.beginPath();
        mCtx.arc(player.x * scale, player.y * scale, 4, 0, Math.PI * 2);
        mCtx.fill();
        mCtx.strokeStyle = 'white';
        mCtx.lineWidth = 1;
        mCtx.stroke();
    }

    function draw() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        
        // 1. Draw World
        ctx.save();
        ctx.translate(-camera.x, -camera.y);

        ctx.strokeStyle = 'rgba(255,255,255,0.05)';
        ctx.lineWidth = 2;
        for (let x = 0; x <= WORLD_SIZE; x += 200) {
            ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x, WORLD_SIZE); ctx.stroke();
        }
        for (let y = 0; y <= WORLD_SIZE; y += 200) {
            ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(WORLD_SIZE, y); ctx.stroke();
        }

        ctx.beginPath();
        ctx.arc(zone.x, zone.y, zone.radius, 0, Math.PI * 2);
        ctx.strokeStyle = '#3b82f6';
        ctx.lineWidth = 12;
        ctx.stroke();
        
        items.forEach(item => {
            ctx.fillStyle = item.type === 'weapon' ? '#facc15' : '#ef4444';
            ctx.beginPath();
            ctx.roundRect(item.x - 12, item.y - 12, 24, 24, 4);
            ctx.fill();
            ctx.fillStyle = 'black';
            ctx.font = 'bold 10px Arial';
            ctx.textAlign = 'center';
            ctx.fillText(item.type === 'weapon' ? '🔫' : '➕', item.x, item.y + 4);
        });

        particles.forEach(p => {
            ctx.globalAlpha = p.life;
            ctx.fillStyle = p.color;
            ctx.beginPath(); ctx.arc(p.x, p.y, 3, 0, Math.PI * 2); ctx.fill();
        });
        ctx.globalAlpha = 1;

        enemies.forEach(en => drawCharacter(en, '#1e293b'));
        drawCharacter(player, '#facc15');

        bullets.forEach(b => {
            ctx.fillStyle = b.color;
            ctx.beginPath(); ctx.arc(b.x, b.y, 4, 0, Math.PI * 2); ctx.fill();
        });

        ctx.restore();

        // 2. Draw Mini Map
        drawMinimap();
    }

    function drawCharacter(char, color) {
        ctx.save();
        ctx.translate(char.x, char.y);
        ctx.rotate(char.angle);
        ctx.fillStyle = color;
        ctx.beginPath(); ctx.arc(0, 0, char.radius, 0, Math.PI * 2); ctx.fill();
        ctx.strokeStyle = 'rgba(0,0,0,0.3)'; ctx.lineWidth = 3; ctx.stroke();
        ctx.fillStyle = color;
        ctx.fillRect(15, -18, 20, 10);
        ctx.fillRect(15, 8, 20, 10);
        ctx.fillStyle = '#333';
        ctx.fillRect(25, -4, 25, 8);
        ctx.restore();
        ctx.fillStyle = '#333';
        ctx.fillRect(char.x - 20, char.y - 40, 40, 5);
        ctx.fillStyle = char.hp > 40 ? '#4ade80' : '#f87171';
        ctx.fillRect(char.x - 20, char.y - 40, (char.hp / 100) * 40, 5);
    }

    function gameOver(text) {
        gameRunning = false;
        overlay.style.display = 'flex';
        overlay.querySelector('h1').innerText = text;
        overlay.querySelector('p').innerText = text === "ELIMINATED" ? "Better luck next time!" : "Winner Winner Chicken Dinner!";
        startBtn.innerText = "PLAY AGAIN";
    }

    function gameLoop() {
        if (!gameRunning) return;
        update();
        draw();
        requestAnimationFrame(gameLoop);
    }

    startBtn.addEventListener('click', () => {
        player.hp = 100;
        player.x = WORLD_SIZE / 2;
        player.y = WORLD_SIZE / 2;
        player.weapon = { name: 'Pistol', damage: 15, cooldown: 400, ammo: 12, maxAmmo: 12, speed: 12, color: '#fbbf24' };
        enemies = [];
        bullets = [];
        items = [];
        particles = [];
        zone.radius = WORLD_SIZE * 0.75;
        zone.targetRadius = WORLD_SIZE * 0.75;
        zoneTimer = 15;
        init();
    });

</script>
</body>
</html>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Pixel Battlegrounds</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body {
            margin: 0;
            padding: 0;
            overflow: hidden;
            background-color: #1a1a1a;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            touch-action: none;
        }
        #game-container {
            position: relative;
            width: 100vw;
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }
        canvas {
            display: block;
            background-color: #4d7c0f; /* Grass color */
            box-shadow: 0 0 50px rgba(0,0,0,0.5);
        }
        #ui-layer {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            color: white;
            padding: 15px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }
        #minimap-container {
            width: 150px;
            height: 150px;
            background: rgba(0, 0, 0, 0.6);
            border: 2px solid rgba(255, 255, 255, 0.3);
            border-radius: 8px;
            overflow: hidden;
            position: relative;
        }
        #minimap-canvas {
            width: 100%;
            height: 100%;
        }
        #overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.8);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            z-index: 100;
            pointer-events: auto;
        }
        .btn {
            background: #facc15;
            color: black;
            padding: 15px 40px;
            border-radius: 8px;
            font-weight: bold;
            cursor: pointer;
            margin-top: 20px;
            transition: transform 0.1s;
        }
        .btn:active { transform: scale(0.95); }
    </style>
</head>
<body>

<div id="game-container">
    <canvas id="gameCanvas"></canvas>
    
    <div id="ui-layer">
        <div class="flex justify-between items-start">
            <div class="flex flex-col gap-2">
                <!-- Mini Map -->
                <div id="minimap-container">
                    <canvas id="minimap-canvas"></canvas>
                </div>
                <!-- Health Bar -->
                <div class="bg-black/50 p-3 rounded border border-white/20">
                    <div id="player-hp-bar" class="w-32 h-3 bg-gray-700 rounded-full overflow-hidden">
                        <div id="player-hp-fill" class="h-full bg-green-500 transition-all duration-300" style="width: 100%"></div>
                    </div>
                    <div class="text-[10px] mt-1 uppercase font-bold tracking-widest">Health</div>
                </div>
            </div>

            <div class="text-right">
                <div class="text-3xl font-black italic text-yellow-400" id="alive-count">ALIVE: 20</div>
                <div class="text-sm font-bold text-blue-300" id="zone-timer">ZONE SHRINKING: 30s</div>
            </div>
        </div>

        <div class="flex justify-between items-end mb-4">
            <div id="weapon-info" class="bg-black/50 p-3 rounded border border-white/20">
                <div class="text-xl font-bold" id="current-weapon">FISTS</div>
                <div class="text-sm text-gray-300" id="ammo-count">∞</div>
            </div>
            
            <div class="flex flex-col gap-2 pointer-events-auto">
                <button id="fire-btn" class="w-24 h-24 bg-red-600/80 rounded-full border-4 border-white/40 active:bg-red-800 flex items-center justify-center shadow-lg">
                    <span class="font-bold text-lg">FIRE</span>
                </button>
            </div>
        </div>
    </div>

    <div id="overlay">
        <h1 class="text-6xl font-black italic text-yellow-400 mb-2">PIXEL BG</h1>
        <p class="text-white text-lg mb-8">Be the last one standing.</p>
        <div class="text-gray-400 text-sm mb-8 text-center">
            WASD / Joystick to Move<br>
            Mouse / Drag to Aim<br>
            Click / Fire Button to Shoot<br>
            Watch the Mini-Map for the Zone!
        </div>
        <div id="start-btn" class="btn text-2xl">START MATCH</div>
    </div>
</div>

<script>
    /** @type {HTMLCanvasElement} */
    const canvas = document.getElementById('gameCanvas');
    const ctx = canvas.getContext('2d');
    const mCanvas = document.getElementById('minimap-canvas');
    const mCtx = mCanvas.getContext('2d');

    const overlay = document.getElementById('overlay');
    const startBtn = document.getElementById('start-btn');
    const hpFill = document.getElementById('player-hp-fill');
    const aliveDisplay = document.getElementById('alive-count');
    const weaponDisplay = document.getElementById('current-weapon');
    const ammoDisplay = document.getElementById('ammo-count');
    const zoneTimerDisplay = document.getElementById('zone-timer');

    // Game Constants
    const WORLD_SIZE = 3000;
    const PLAYER_SPEED = 4.5;
    const AI_COUNT = 19;
    
    // State
    let gameRunning = false;
    let player = {
        x: WORLD_SIZE / 2,
        y: WORLD_SIZE / 2,
        radius: 20,
        angle: 0,
        hp: 100,
        weapon: { name: 'Pistol', damage: 15, cooldown: 400, ammo: 12, maxAmmo: 12, speed: 12, color: '#fbbf24' },
        lastShot: 0
    };

    let camera = { x: 0, y: 0 };
    let keys = {};
    let enemies = [];
    let bullets = [];
    let items = [];
    let particles = [];
    let zone = { x: WORLD_SIZE/2, y: WORLD_SIZE/2, radius: WORLD_SIZE * 0.75, targetRadius: WORLD_SIZE * 0.75 };
    let zoneTimer = 15; 
    let aliveCount = AI_COUNT + 1;

    // Initialization
    function init() {
        resize();
        spawnEnemies();
        spawnItems();
        gameRunning = true;
        overlay.style.display = 'none';
        requestAnimationFrame(gameLoop);
        
        const timerInt = setInterval(() => {
            if (!gameRunning) { clearInterval(timerInt); return; }
            if (zoneTimer > 0) zoneTimer--;
            else {
                zone.targetRadius *= 0.7;
                zoneTimer = 25;
            }
            zoneTimerDisplay.innerText = `NEXT SHRINK: ${zoneTimer}s`;
        }, 1000);
    }

    function resize() {
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
        // Map canvas resolution
        mCanvas.width = 150;
        mCanvas.height = 150;
    }

    window.addEventListener('resize', resize);

    // Input Handling
    window.addEventListener('keydown', e => keys[e.code] = true);
    window.addEventListener('keyup', e => keys[e.code] = false);
    
    let isMouseDown = false;
    let mousePos = { x: 0, y: 0 };

    canvas.addEventListener('mousemove', e => {
        mousePos.x = e.clientX;
        mousePos.y = e.clientY;
    });
    canvas.addEventListener('mousedown', () => isMouseDown = true);
    canvas.addEventListener('mouseup', () => isMouseDown = false);
    document.getElementById('fire-btn').addEventListener('touchstart', (e) => { e.preventDefault(); isMouseDown = true; });
    document.getElementById('fire-btn').addEventListener('touchend', () => isMouseDown = false);

    function spawnEnemies() {
        for(let i=0; i<AI_COUNT; i++) {
            enemies.push({
                x: Math.random() * WORLD_SIZE,
                y: Math.random() * WORLD_SIZE,
                radius: 20,
                hp: 100,
                angle: Math.random() * Math.PI * 2,
                weapon: { name: 'Pistol', damage: 10, cooldown: 1000, speed: 8 },
                lastShot: 0,
                targetX: Math.random() * WORLD_SIZE,
                targetY: Math.random() * WORLD_SIZE,
                aiTimer: 0
            });
        }
    }

    function spawnItems() {
        const weaponTypes = [
            { name: 'SMG', damage: 8, cooldown: 120, ammo: 30, maxAmmo: 30, speed: 15, color: '#f87171' },
            { name: 'Rifle', damage: 25, cooldown: 600, ammo: 10, maxAmmo: 10, speed: 20, color: '#60a5fa' }
        ];
        for(let i=0; i<60; i++) {
            items.push({
                x: Math.random() * WORLD_SIZE,
                y: Math.random() * WORLD_SIZE,
                type: Math.random() > 0.4 ? 'weapon' : 'health',
                data: Math.random() > 0.5 ? weaponTypes[0] : weaponTypes[1]
            });
        }
    }

    function shoot(owner, isPlayer = false) {
        const now = Date.now();
        if (now - owner.lastShot < owner.weapon.cooldown) return;
        if (isPlayer && owner.weapon.ammo <= 0) return;

        owner.lastShot = now;
        if (isPlayer) owner.weapon.ammo--;

        bullets.push({
            x: owner.x + Math.cos(owner.angle) * 30,
            y: owner.y + Math.sin(owner.angle) * 30,
            vx: Math.cos(owner.angle) * owner.weapon.speed,
            vy: Math.sin(owner.angle) * owner.weapon.speed,
            damage: owner.weapon.damage,
            owner: owner,
            color: owner.weapon.color || 'white'
        });

        createExplosion(owner.x + Math.cos(owner.angle) * 25, owner.y + Math.sin(owner.angle) * 25, owner.weapon.color, 3);
    }

    function createExplosion(x, y, color, count = 10) {
        for(let i=0; i<count; i++) {
            particles.push({
                x, y,
                vx: (Math.random() - 0.5) * 5,
                vy: (Math.random() - 0.5) * 5,
                life: 1.0,
                color: color || '#fff'
            });
        }
    }

    function update() {
        // Player Movement
        let dx = 0, dy = 0;
        if (keys['KeyW'] || keys['ArrowUp']) dy -= 1;
        if (keys['KeyS'] || keys['ArrowDown']) dy += 1;
        if (keys['KeyA'] || keys['ArrowLeft']) dx -= 1;
        if (keys['KeyD'] || keys['ArrowRight']) dx += 1;

        if (dx !== 0 || dy !== 0) {
            const mag = Math.sqrt(dx*dx + dy*dy);
            player.x += (dx/mag) * PLAYER_SPEED;
            player.y += (dy/mag) * PLAYER_SPEED;
        }

        const screenCenterX = canvas.width / 2;
        const screenCenterY = canvas.height / 2;
        player.angle = Math.atan2(mousePos.y - screenCenterY, mousePos.x - screenCenterX);

        if (isMouseDown) shoot(player, true);

        player.x = Math.max(0, Math.min(WORLD_SIZE, player.x));
        player.y = Math.max(0, Math.min(WORLD_SIZE, player.y));

        camera.x = player.x - canvas.width / 2;
        camera.y = player.y - canvas.height / 2;

        if (zone.radius > zone.targetRadius) zone.radius -= 0.3;
        const distToZoneCenter = Math.sqrt((player.x - zone.x)**2 + (player.y - zone.y)**2);
        if (distToZoneCenter > zone.radius) player.hp -= 0.15;

        items = items.filter(item => {
            const dist = Math.sqrt((player.x - item.x)**2 + (player.y - item.y)**2);
            if (dist < 40) {
                if (item.type === 'weapon') player.weapon = JSON.parse(JSON.stringify(item.data));
                else player.hp = Math.min(100, player.hp + 40);
                return false;
            }
            return true;
        });

        enemies.forEach(en => {
            en.aiTimer--;
            if(en.aiTimer <= 0) {
                en.targetX = Math.random() * WORLD_SIZE;
                en.targetY = Math.random() * WORLD_SIZE;
                en.aiTimer = 100 + Math.random() * 200;
            }
            const edx = en.targetX - en.x;
            const edy = en.targetY - en.y;
            const edist = Math.sqrt(edx*edx + edy*edy);
            if (edist > 5) {
                en.x += (edx/edist) * 2.2;
                en.y += (edy/edist) * 2.2;
                en.angle = Math.atan2(edy, edx);
            }

            const distToPlayer = Math.sqrt((player.x - en.x)**2 + (player.y - en.y)**2);
            if (distToPlayer < 450) {
                en.angle = Math.atan2(player.y - en.y, player.x - en.x);
                shoot(en);
            }

            const distToZone = Math.sqrt((en.x - zone.x)**2 + (en.y - zone.y)**2);
            if (distToZone > zone.radius) en.hp -= 0.3;
        });

        bullets.forEach((b, i) => {
            b.x += b.vx;
            b.y += b.vy;

            if (b.owner !== player) {
                const d = Math.sqrt((b.x - player.x)**2 + (b.y - player.y)**2);
                if (d < player.radius) {
                    player.hp -= b.damage;
                    createExplosion(b.x, b.y, 'red', 5);
                    bullets.splice(i, 1);
                    return;
                }
            }

            enemies.forEach((en, ei) => {
                if (b.owner !== en) {
                    const d = Math.sqrt((b.x - en.x)**2 + (b.y - en.y)**2);
                    if (d < en.radius) {
                        en.hp -= b.damage;
                        createExplosion(b.x, b.y, 'white', 5);
                        bullets.splice(i, 1);
                        if (en.hp <= 0) {
                            enemies.splice(ei, 1);
                            createExplosion(en.x, en.y, '#555', 20);
                        }
                    }
                }
            });

            if (b.x < 0 || b.x > WORLD_SIZE || b.y < 0 || b.y > WORLD_SIZE) bullets.splice(i, 1);
        });

        particles.forEach((p, i) => {
            p.x += p.vx;
            p.y += p.vy;
            p.life -= 0.02;
            if (p.life <= 0) particles.splice(i, 1);
        });

        hpFill.style.width = Math.max(0, player.hp) + '%';
        aliveCount = enemies.length + 1;
        aliveDisplay.innerText = `ALIVE: ${aliveCount}`;
        weaponDisplay.innerText = player.weapon.name;
        ammoDisplay.innerText = player.weapon.ammo !== undefined ? player.weapon.ammo : '∞';

        if (player.hp <= 0) gameOver("ELIMINATED");
        if (aliveCount === 1 && player.hp > 0) gameOver("WINNER WINNER!");
    }

    function drawMinimap() {
        mCtx.fillStyle = 'rgba(0, 0, 0, 0.8)';
        mCtx.fillRect(0, 0, mCanvas.width, mCanvas.height);

        const scale = mCanvas.width / WORLD_SIZE;

        // Draw Zone in Map
        mCtx.beginPath();
        mCtx.arc(zone.x * scale, zone.y * scale, zone.radius * scale, 0, Math.PI * 2);
        mCtx.strokeStyle = '#3b82f6';
        mCtx.lineWidth = 1.5;
        mCtx.stroke();

        // Items
        items.forEach(item => {
            mCtx.fillStyle = item.type === 'weapon' ? '#facc15' : '#ef4444';
            mCtx.fillRect(item.x * scale - 1, item.y * scale - 1, 2, 2);
        });

        // Enemies
        mCtx.fillStyle = '#ef4444';
        enemies.forEach(en => {
            mCtx.beginPath();
            mCtx.arc(en.x * scale, en.y * scale, 2.5, 0, Math.PI * 2);
            mCtx.fill();
        });

        // Player
        mCtx.fillStyle = '#facc15';
        mCtx.beginPath();
        mCtx.arc(player.x * scale, player.y * scale, 4, 0, Math.PI * 2);
        mCtx.fill();
        mCtx.strokeStyle = 'white';
        mCtx.lineWidth = 1;
        mCtx.stroke();
    }

    function draw() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        
        // 1. Draw World
        ctx.save();
        ctx.translate(-camera.x, -camera.y);

        ctx.strokeStyle = 'rgba(255,255,255,0.05)';
        ctx.lineWidth = 2;
        for (let x = 0; x <= WORLD_SIZE; x += 200) {
            ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x, WORLD_SIZE); ctx.stroke();
        }
        for (let y = 0; y <= WORLD_SIZE; y += 200) {
            ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(WORLD_SIZE, y); ctx.stroke();
        }

        ctx.beginPath();
        ctx.arc(zone.x, zone.y, zone.radius, 0, Math.PI * 2);
        ctx.strokeStyle = '#3b82f6';
        ctx.lineWidth = 12;
        ctx.stroke();
        
        items.forEach(item => {
            ctx.fillStyle = item.type === 'weapon' ? '#facc15' : '#ef4444';
            ctx.beginPath();
            ctx.roundRect(item.x - 12, item.y - 12, 24, 24, 4);
            ctx.fill();
            ctx.fillStyle = 'black';
            ctx.font = 'bold 10px Arial';
            ctx.textAlign = 'center';
            ctx.fillText(item.type === 'weapon' ? '🔫' : '➕', item.x, item.y + 4);
        });

        particles.forEach(p => {
            ctx.globalAlpha = p.life;
            ctx.fillStyle = p.color;
            ctx.beginPath(); ctx.arc(p.x, p.y, 3, 0, Math.PI * 2); ctx.fill();
        });
        ctx.globalAlpha = 1;

        enemies.forEach(en => drawCharacter(en, '#1e293b'));
        drawCharacter(player, '#facc15');

        bullets.forEach(b => {
            ctx.fillStyle = b.color;
            ctx.beginPath(); ctx.arc(b.x, b.y, 4, 0, Math.PI * 2); ctx.fill();
        });

        ctx.restore();

        // 2. Draw Mini Map
        drawMinimap();
    }

    function drawCharacter(char, color) {
        ctx.save();
        ctx.translate(char.x, char.y);
        ctx.rotate(char.angle);
        ctx.fillStyle = color;
        ctx.beginPath(); ctx.arc(0, 0, char.radius, 0, Math.PI * 2); ctx.fill();
        ctx.strokeStyle = 'rgba(0,0,0,0.3)'; ctx.lineWidth = 3; ctx.stroke();
        ctx.fillStyle = color;
        ctx.fillRect(15, -18, 20, 10);
        ctx.fillRect(15, 8, 20, 10);
        ctx.fillStyle = '#333';
        ctx.fillRect(25, -4, 25, 8);
        ctx.restore();
        ctx.fillStyle = '#333';
        ctx.fillRect(char.x - 20, char.y - 40, 40, 5);
        ctx.fillStyle = char.hp > 40 ? '#4ade80' : '#f87171';
        ctx.fillRect(char.x - 20, char.y - 40, (char.hp / 100) * 40, 5);
    }

    function gameOver(text) {
        gameRunning = false;
        overlay.style.display = 'flex';
        overlay.querySelector('h1').innerText = text;
        overlay.querySelector('p').innerText = text === "ELIMINATED" ? "Better luck next time!" : "Winner Winner Chicken Dinner!";
        startBtn.innerText = "PLAY AGAIN";
    }

    function gameLoop() {
        if (!gameRunning) return;
        update();
        draw();
        requestAnimationFrame(gameLoop);
    }

    startBtn.addEventListener('click', () => {
        player.hp = 100;
        player.x = WORLD_SIZE / 2;
        player.y = WORLD_SIZE / 2;
        player.weapon = { name: 'Pistol', damage: 15, cooldown: 400, ammo: 12, maxAmmo: 12, speed: 12, color: '#fbbf24' };
        enemies = [];
        bullets = [];
        items = [];
        particles = [];
        zone.radius = WORLD_SIZE * 0.75;
        zone.targetRadius = WORLD_SIZE * 0.75;
        zoneTimer = 15;
        init();
    });

</script>
</body>
</html>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>RADIUS REDACTED</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Courier+Prime:wght@400;700&family=Orbitron:wght@400;900&display=swap" rel="stylesheet">
    <style>
        :root {
            --redact-red: #ff3e3e;
            --ui-bg: rgba(10, 10, 10, 0.95);
        }
        body {
            margin: 0;
            overflow: hidden;
            background-color: #0a0a0a;
            font-family: 'Courier Prime', monospace;
            touch-action: none;
            color: #eee;
        }
        canvas { display: block; }
        
        .orbitron { font-family: 'Orbitron', sans-serif; }
        
        /* Glitch Effect for Title */
        .glitch {
            position: relative;
            display: inline-block;
        }
        .glitch::before, .glitch::after {
            content: attr(data-text);
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            background: #0a0a0a;
        }
        .glitch::before {
            left: 2px;
            text-shadow: -2px 0 #ff00c1;
            clip: rect(44px, 450px, 56px, 0);
            animation: glitch-anim 5s infinite linear alternate-reverse;
        }
        .glitch::after {
            left: -2px;
            text-shadow: -2px 0 #00fff9;
            clip: rect(44px, 450px, 56px, 0);
            animation: glitch-anim2 5s infinite linear alternate-reverse;
        }
        @keyframes glitch-anim {
            0% { clip: rect(31px, 9999px, 94px, 0); }
            20% { clip: rect(62px, 9999px, 42px, 0); }
            100% { clip: rect(89px, 9999px, 98px, 0); }
        }
        @keyframes glitch-anim2 {
            0% { clip: rect(10px, 9999px, 85px, 0); }
            20% { clip: rect(40px, 9999px, 20px, 0); }
            100% { clip: rect(70px, 9999px, 90px, 0); }
        }

        #ui-layer { pointer-events: none; }
        .interactive { pointer-events: auto; }
        
        .crt-overlay {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.1) 50%),
                        linear-gradient(90deg, rgba(255, 0, 0, 0.03), rgba(0, 255, 0, 0.01), rgba(0, 0, 255, 0.03));
            background-size: 100% 2px, 3px 100%;
            pointer-events: none;
            z-index: 100;
        }
    </style>
</head>
<body>

    <div class="crt-overlay"></div>

    <!-- Main Menu -->
    <div id="menu" class="absolute inset-0 z-[110] flex items-center justify-center bg-black/95 p-6">
        <div class="max-w-lg w-full text-center border-y border-white/10 py-12">
            <h1 class="orbitron text-4xl md:text-6xl font-black text-white mb-2 glitch" data-text="RADIUS">RADIUS</h1>
            <div class="bg-white text-black orbitron px-4 py-1 inline-block font-bold tracking-[0.4em] mb-12">REDACTED</div>
            
            <p class="text-zinc-500 mb-6 uppercase text-[10px] tracking-widest">[ SELECT OPERATIVE SKIN ]</p>
            
            <div class="grid grid-cols-3 gap-4 mb-12 px-4">
                <button onclick="selectSkin('Ghost', '#888')" class="skin-btn interactive border border-zinc-800 p-4 bg-zinc-900/50 hover:bg-zinc-800 transition-all" id="skin-Ghost">
                    <div class="w-10 h-10 bg-zinc-400 mx-auto mb-2 opacity-50"></div>
                    <span class="text-[9px] text-zinc-500 font-bold uppercase">GHOST</span>
                </button>
                <button onclick="selectSkin('Viper', '#34d399')" class="skin-btn interactive border border-zinc-800 p-4 bg-zinc-900/50 hover:bg-zinc-800 transition-all" id="skin-Viper">
                    <div class="w-10 h-10 bg-emerald-500 mx-auto mb-2 opacity-50"></div>
                    <span class="text-[9px] text-zinc-500 font-bold uppercase">VIPER</span>
                </button>
                <button onclick="selectSkin('Titan', '#f87171')" class="skin-btn interactive border border-zinc-800 p-4 bg-zinc-900/50 hover:bg-zinc-800 transition-all" id="skin-Titan">
                    <div class="w-10 h-10 bg-red-500 mx-auto mb-2 opacity-50"></div>
                    <span class="text-[9px] text-zinc-500 font-bold uppercase">TITAN</span>
                </button>
            </div>

            <button onclick="startGame()" class="interactive orbitron w-64 bg-red-600 hover:bg-red-500 text-white font-bold py-4 rounded-none uppercase tracking-widest transition-all shadow-[0_0_20px_rgba(220,38,38,0.4)]">
                DEPLOY
            </button>
        </div>
    </div>

    <!-- HUD -->
    <div id="ui-layer" class="absolute inset-0 z-10 hidden flex flex-col justify-between p-8">
        <div class="flex justify-between items-start">
            <div class="bg-black/60 p-4 border-l-2 border-red-600 backdrop-blur-sm">
                <div class="text-red-500 text-[10px] font-bold uppercase tracking-widest mb-1">OPERATIVES ACTIVE</div>
                <div id="alive-count" class="text-white text-4xl font-black orbitron">--</div>
            </div>
            <div class="text-right">
                <div class="text-white/30 text-[10px] font-bold uppercase tracking-widest mb-1">RADIUS STATUS</div>
                <div class="text-red-600 text-sm font-bold uppercase orbitron animate-pulse">COLLAPSING...</div>
            </div>
        </div>

        <div class="flex flex-col items-center mb-8">
            <div class="text-white text-[9px] uppercase tracking-[0.3em] mb-2 opacity-50 font-bold">VITAL SIGNALS</div>
            <div class="w-80 bg-zinc-900 h-1 overflow-hidden relative">
                <div id="health-bar" class="h-full bg-red-600 transition-all duration-200" style="width: 100%;"></div>
            </div>
        </div>
    </div>

    <canvas id="gameCanvas"></canvas>

    <script>
        const canvas = document.getElementById('gameCanvas');
        const ctx = canvas.getContext('2d');
        const menu = document.getElementById('menu');
        const hud = document.getElementById('ui-layer');
        const healthBar = document.getElementById('health-bar');
        const aliveCountDisplay = document.getElementById('alive-count');

        let gameActive = false;
        let selectedColor = '#888';
        const WORLD_SIZE = 4000;

        const player = {
            x: WORLD_SIZE / 2, y: WORLD_SIZE / 2,
            radius: 15, speed: 6.5, health: 100,
            angle: 0, color: '#888'
        };

        const enemies = [];
        const enemyCount = 29;
        const bullets = [];
        const particles = [];
        const zone = {
            x: WORLD_SIZE / 2, y: WORLD_SIZE / 2,
            radius: WORLD_SIZE / 1.5,
            shrinkSpeed: 0.3
        };

        const keys = {};

        function resize() {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
        }
        window.addEventListener('resize', resize);
        resize();

        window.addEventListener('keydown', e => keys[e.code] = true);
        window.addEventListener('keyup', e => keys[e.code] = false);
        window.addEventListener('mousemove', e => {
            if (!gameActive) return;
            player.angle = Math.atan2(e.clientY - canvas.height/2, e.clientX - canvas.width/2);
        });
        window.addEventListener('mousedown', () => { if (gameActive) shoot(player); });

        function selectSkin(name, color) {
            selectedColor = color;
            document.querySelectorAll('.skin-btn').forEach(btn => {
                btn.style.borderColor = '#27272a';
                btn.querySelector('div').style.opacity = '0.3';
            });
            const activeBtn = document.getElementById('skin-' + name);
            activeBtn.style.borderColor = '#ef4444';
            activeBtn.querySelector('div').style.opacity = '1';
        }
        selectSkin('Ghost', '#888');

        function startGame() {
            player.color = selectedColor;
            menu.classList.add('hidden');
            hud.classList.remove('hidden');
            gameActive = true;
            initEnemies();
            requestAnimationFrame(gameLoop);
        }

        function initEnemies() {
            const eColors = ['#ef4444', '#34d399', '#60a5fa', '#fbbf24'];
            for (let i = 0; i < enemyCount; i++) {
                enemies.push({
                    x: Math.random() * WORLD_SIZE,
                    y: Math.random() * WORLD_SIZE,
                    radius: 15, speed: 4 + Math.random() * 2,
                    health: 100, angle: Math.random() * Math.PI * 2,
                    color: eColors[Math.floor(Math.random() * eColors.length)],
                    lastShot: 0
                });
            }
        }

        function shoot(entity) {
            bullets.push({
                x: entity.x + Math.cos(entity.angle) * 20,
                y: entity.y + Math.sin(entity.angle) * 20,
                vx: Math.cos(entity.angle) * 18,
                vy: Math.sin(entity.angle) * 18,
                owner: entity, life: 60, color: entity.color
            });
        }

        function spawnParticles(x, y, color) {
            for(let i=0; i<15; i++) {
                particles.push({
                    x, y,
                    vx: (Math.random() - 0.5) * 15,
                    vy: (Math.random() - 0.5) * 15,
                    life: 1.0, color
                });
            }
        }

        function update() {
            if (!gameActive) return;

            // Player movement
            let dx = 0, dy = 0;
            if (keys['KeyW']) dy -= 1; if (keys['KeyS']) dy += 1;
            if (keys['KeyA']) dx -= 1; if (keys['KeyD']) dx += 1;
            if (dx !== 0 || dy !== 0) {
                const mag = Math.hypot(dx, dy);
                player.x += (dx/mag) * player.speed;
                player.y += (dy/mag) * player.speed;
            }

            zone.radius -= zone.shrinkSpeed;
            if (zone.radius < 50) zone.radius = 50;
            if (Math.hypot(player.x - zone.x, player.y - zone.y) > zone.radius) player.health -= 0.2;

            enemies.forEach(enemy => {
                const dist = Math.hypot(player.x - enemy.x, player.y - enemy.y);
                if (dist < 800) {
                    enemy.angle = Math.atan2(player.y - enemy.y, player.x - enemy.x);
                    enemy.x += Math.cos(enemy.angle) * enemy.speed;
                    enemy.y += Math.sin(enemy.angle) * enemy.speed;
                    if (Date.now() - enemy.lastShot > 1400) {
                        shoot(enemy);
                        enemy.lastShot = Date.now();
                    }
                }
                if (Math.hypot(enemy.x - zone.x, enemy.y - zone.y) > zone.radius) enemy.health -= 0.4;
            });

            for (let i = bullets.length - 1; i >= 0; i--) {
                const b = bullets[i];
                b.x += b.vx; b.y += b.vy; b.life--;
                if (b.owner === player) {
                    for (let j = enemies.length - 1; j >= 0; j--) {
                        if (Math.hypot(b.x - enemies[j].x, b.y - enemies[j].y) < 15) {
                            enemies[j].health -= 35;
                            spawnParticles(enemies[j].x, enemies[j].y, enemies[j].color);
                            bullets.splice(i, 1); break;
                        }
                    }
                } else if (Math.hypot(b.x - player.x, b.y - player.y) < 15) {
                    player.health -= 15;
                    spawnParticles(player.x, player.y, player.color);
                    bullets.splice(i, 1);
                }
                if (b && b.life <= 0) bullets.splice(i, 1);
            }

            for (let i = enemies.length - 1; i >= 0; i--) if (enemies[i].health <= 0) enemies.splice(i, 1);
            
            healthBar.style.width = Math.max(0, player.health) + '%';
            aliveCountDisplay.innerText = (enemies.length + 1).toString().padStart(2, '0');

            if (player.health <= 0) endGame(false);
            if (enemies.length === 0) endGame(true);
        }

        function draw() {
            ctx.fillStyle = '#0a0a0a';
            ctx.fillRect(0, 0, canvas.width, canvas.height);
            
            ctx.save();
            ctx.translate(canvas.width/2 - player.x, canvas.height/2 - player.y);

            // Grid
            ctx.strokeStyle = '#151515';
            for(let i=0; i<=WORLD_SIZE; i+=200) {
                ctx.beginPath(); ctx.moveTo(i, 0); ctx.lineTo(i, WORLD_SIZE); ctx.stroke();
                ctx.beginPath(); ctx.moveTo(0, i); ctx.lineTo(WORLD_SIZE, i); ctx.stroke();
            }

            // The Radius (Zone)
            ctx.beginPath();
            ctx.arc(zone.x, zone.y, zone.radius, 0, Math.PI*2);
            ctx.strokeStyle = '#ef4444';
            ctx.lineWidth = 2;
            ctx.stroke();

            // Particles
            particles.forEach((p, i) => {
                p.life -= 0.03;
                p.x += p.vx; p.y += p.vy;
                ctx.fillStyle = p.color;
                ctx.globalAlpha = p.life;
                ctx.fillRect(p.x, p.y, 3, 3);
                if (p.life <= 0) particles.splice(i, 1);
            });
            ctx.globalAlpha = 1.0;

            bullets.forEach(b => {
                ctx.fillStyle = '#fff';
                ctx.beginPath(); ctx.arc(b.x, b.y, 4, 0, Math.PI*2); ctx.fill();
            });

            enemies.forEach(e => drawUnit(e));
            drawUnit(player);

            ctx.restore();
        }

        function drawUnit(u) {
            ctx.save();
            ctx.translate(u.x, u.y);
            ctx.rotate(u.angle);
            // Unit Body
            ctx.fillStyle = u.color;
            ctx.fillRect(-12, -12, 24, 24);
            ctx.strokeStyle = '#000';
            ctx.strokeRect(-12, -12, 24, 24);
            // Gun
            ctx.fillStyle = '#fff';
            ctx.fillRect(10, -2, 12, 4);
            ctx.restore();
        }

        function endGame(win) {
            gameActive = false;
            menu.innerHTML = `
                <div class="text-center border-y border-white/10 py-12 w-full">
                    <h1 class="orbitron text-5xl font-black mb-4 ${win ? 'text-green-500' : 'text-red-600'}">${win ? 'SUCCESS' : 'REDACTED'}</h1>
                    <p class="text-zinc-500 mb-12 uppercase tracking-[0.4em] text-xs">${win ? 'OPERATIVE SECURED' : 'SIGNAL TERMINATED'}</p>
                    <button onclick="location.reload()" class="orbitron bg-white text-black px-12 py-4 font-bold hover:bg-red-600 hover:text-white transition-all">REDEPLOY</button>
                </div>
            `;
            menu.classList.remove('hidden');
        }

        function gameLoop() {
            if (!gameActive) return;
            update();
            draw();
            requestAnimationFrame(gameLoop);
        }
    </script>
</body>
</html>
